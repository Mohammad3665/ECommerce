{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Redis": {
    "ConnectionString": "redis:6379,abortConnect=false",
    "InstanceName": "ECommerce"
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyMustBeVeryLongToSatisfySecurityAlgorithms123!",
    "Issuer": "ECommerceApi",
    "Audience": "ECommerceClient",
    "ExpiryInMinutes": 60
  },
  "ZarinPal": {
    "MerchantId": "00000000-0000-0000-0000-000000000000",
    "CallbackUrl": "http://host.docker.internal:5000/Api/V1/Payment/Verify"
  },
  "AllowedHosts": "*"
}
