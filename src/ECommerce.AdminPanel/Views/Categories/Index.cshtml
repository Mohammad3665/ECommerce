@{
    ViewData["Title"] = "مدیریت دسته‌بندی‌ها";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">مدیریت دسته‌بندی‌ها</h4>
                    </div>
                    <div class="ml-auto">
                        <a asp-action="Create" class="btn btn-info">
                            <i class="mdi mdi-folder-plus"></i> افزودن دسته‌بندی
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-4 col-md-6">
        <div class="card" style="overflow: hidden;">
            <div style="height: 180px; overflow: hidden; background: #f1f2f3; display: flex; align-items: center; justify-content: center;">
                <img src="~/assets/images/background/img5.png" alt="دسته‌بندی" style="width: 100%; height: 180px; object-fit: cover;">
            </div>
            <div class="card-body">
                <h5 class="card-title m-b-0">نام دسته‌بندی</h5>
                <p class="text-muted m-t-10 m-b-0" style="font-size: 13px;">توضیحات دسته‌بندی اینجا قرار می‌گیرد</p>
                <div class="d-flex justify-content-between align-items-center m-t-15">
                    <div>
                        <span class="badge badge-pill badge-success">فعال</span>
                        <span class="text-muted font-12 m-l-10">۱۲ محصول</span>
                    </div>
                    <div>
                        <a asp-action="Edit" asp-route-id="1" class="btn btn-sm btn-outline-warning" title="ویرایش">
                            <i class="mdi mdi-lead-pencil"></i>
                        </a>
                        <a href="javascript:void(0)" class="btn btn-sm btn-outline-danger" title="حذف">
                            <i class="mdi mdi-delete"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
