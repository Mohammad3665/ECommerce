@{
    ViewData["Title"] = "لیست نقش‌ها";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">لیست نقش‌ها</h4>
                    </div>
                    <div class="ml-auto">
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="mdi mdi-shield-plus"></i> افزودن نقش جدید
                        </a>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover" id="zero_config">
                    <thead>
                        <tr>
                            <th class="border-top-0">نام نقش</th>
                            <th class="border-top-0">نام نمایشی</th>
                            <th class="border-top-0">توضیحات</th>
                            <th class="border-top-0">سطح</th>
                            <th class="border-top-0">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                <i class="mdi mdi-information-outline font-24"></i>
                                <p class="m-t-10">داده‌ای یافت نشد</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
