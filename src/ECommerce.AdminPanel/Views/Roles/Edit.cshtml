@model ECommerce.AdminPanel.Models.RoleFormViewModel
@{
    ViewData["Title"] = "ویرایش نقش";
    var permissionsByModule = ViewBag.PermissionsByModule as Dictionary<string, List<PermissionViewModel>> ?? new();
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">ویرایش نقش: @Model.DisplayName</h4>
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Slug" />
                    <input type="hidden" asp-for="Id" />
                    <div class="form-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="control-label">نام سیستمی</label>
                                    <input asp-for="Name" class="form-control" readonly />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="control-label">نام نمایشی</label>
                                    <input asp-for="DisplayName" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="control-label">سطح دسترسی</label>
                                    <input asp-for="Level" class="form-control" type="number" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">توضیحات</label>
                                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <div class="custom-control custom-checkbox mb-3">
                                        <input asp-for="GrantAllPermissions" class="custom-control-input" id="grantAll" onchange="toggleAllPermissions(this)">
                                        <label class="custom-control-label" for="grantAll"><strong>اعطای تمام دسترسی‌ها</strong></label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="permissionsSection">
                            @foreach (var module in permissionsByModule.Keys.OrderBy(k => k))
                            {
                                <div class="card mb-3">
                                    <div class="card-header py-2">
                                        <h6 class="mb-0">
                                            <i class="mdi mdi-lock"></i> @module
                                        </h6>
                                    </div>
                                    <div class="card-body py-2">
                                        <div class="row">
                                            @foreach (var perm in permissionsByModule[module])
                                            {
                                                <div class="col-md-4 col-sm-6">
                                                    <div class="custom-control custom-checkbox">
                                                        <input type="checkbox" name="SelectedPermissionIds" value="@perm.Id"
                                                               class="custom-control-input permission-cb" id="perm_@perm.Id"
                                                               @(Model.SelectedPermissionIds != null && Model.SelectedPermissionIds.Contains(perm.Id) ? "checked" : "")>
                                                        <label class="custom-control-label" for="perm_@perm.Id">
                                                            <small>@perm.Name</small>
                                                            <br />
                                                            <small class="text-muted">@perm.Description</small>
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-success">
                            <i class="mdi mdi-content-save"></i> ذخیره تغییرات
                        </button>
                        <a asp-action="Index" class="btn btn-inverse">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleAllPermissions(checkbox) {
            var cbs = document.querySelectorAll('.permission-cb');
            cbs.forEach(function (cb) { cb.checked = checkbox.checked; });
        }
    </script>
}
