@model List<ECommerce.AdminPanel.Models.SlideListViewModel>
@{
    ViewData["Title"] = "مدیریت اسلایدرها";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">مدیریت اسلایدرها</h4>
                    </div>
                    <div class="ml-auto">
                        <a asp-action="Create" class="btn btn-teal">
                            <i class="mdi mdi-view-carousel-plus"></i> افزودن اسلایدر جدید
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    @if (Model.Any())
    {
        @foreach (var slide in Model)
        {
            <div class="col-lg-6 col-md-12">
                <div class="card" style="overflow: hidden;">
                    <div style="height: 220px; overflow: hidden; background: #f1f2f3; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(slide.ImageUrl))
                        {
                            <img src="~/@slide.ImageUrl" alt="@slide.Title" style="width: 100%; height: 220px; object-fit: cover;">
                        }
                        else
                        {
                            <i class="mdi mdi-view-carousel text-muted" style="font-size: 48px;"></i>
                        }
                    </div>
                    <div class="card-body">
                        <h5 class="card-title m-b-0">@slide.Title</h5>
                        <p class="text-muted m-t-10 m-b-0" style="font-size: 13px;">@slide.Description</p>
                        <div class="d-flex justify-content-between align-items-center m-t-15">
                            <div>
                                <span class="badge @(slide.IsActive ? "badge-success" : "badge-danger") badge-pill">@(slide.IsActive ? "فعال" : "غیرفعال")</span>
                                <span class="text-muted font-12 m-l-10">ترتیب: @slide.DisplayOrder</span>
                            </div>
                            <div>
                                <a asp-action="Edit" asp-route-id="@slide.Id" class="btn btn-sm btn-outline-warning" title="ویرایش">
                                    <i class="mdi mdi-lead-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@slide.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف" onclick="return confirm('آیا مطمئن هستید؟')">
                                        <i class="mdi mdi-delete"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body text-center text-muted">
                    <i class="mdi mdi-information-outline font-24"></i>
                    <p class="m-t-10">داده‌ای یافت نشد</p>
                </div>
            </div>
        </div>
    }
</div>
