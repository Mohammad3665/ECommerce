@model ECommerce.AdminPanel.Models.CategoryFormViewModel
@{
    ViewData["Title"] = "ویرایش دسته‌بندی";
    var parentCategories = ViewBag.ParentCategories as List<ParentCategoryDto> ?? [];
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">ویرایش دسته‌بندی</h4>
                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Slug" />
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ExistingImageUrl" />
                    <div class="form-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">نام</label>
                                    <input asp-for="Name" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">نام انگلیسی</label>
                                    <input asp-for="EnglishName" class="form-control" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">توضیحات</label>
                                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">دسته‌بندی والد</label>
                                    <select asp-for="ParentCategoryId" class="form-control">
                                        <option value="">بدون والد</option>
                                        @foreach (ParentCategoryDto cat in parentCategories)
                                        {
                                            if (Model.ParentCategoryId.HasValue && Model.ParentCategoryId.Value == cat.Id)
                                            {
                                                <option value="@cat.Id" selected>@cat.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@cat.Id">@cat.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="control-label">وضعیت</label>
                                    <select asp-for="IsActive" class="form-control">
                                        @if (Model.IsActive)
                                        {
                                            <option value="true" selected>فعال</option>
                                            <option value="false">غیرفعال</option>
                                        }
                                        else
                                        {
                                            <option value="true">فعال</option>
                                            <option value="false" selected>غیرفعال</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">تصویر فعلی</label>
                                    <div>
                                        @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                                        {
                                            <img src="~/@Model.ExistingImageUrl" style="width: 150px; height: 150px; object-fit: cover; border-radius: 5px;" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">تصویری آپلود نشده است</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">تصویر جدید</label>
                                    <div class="custom-file">
                                        <input type="file" name="ImageFile" class="custom-file-input" id="imageUpload" accept="image/*">
                                        <label class="custom-file-label" for="imageUpload">انتخاب تصویر جدید</label>
                                    </div>
                                    <div class="mt-2">
                                        <img id="imagePreview" src="#" alt="پیش‌نمایش" style="max-width: 300px; max-height: 200px; display: none; border-radius: 5px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-success">
                            <i class="mdi mdi-content-save"></i> ذخیره تغییرات
                        </button>
                        <a asp-action="Index" class="btn btn-inverse">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('imageUpload').addEventListener('change', function (e) {
            var preview = document.getElementById('imagePreview');
            var file = e.target.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function (event) {
                    preview.src = event.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
