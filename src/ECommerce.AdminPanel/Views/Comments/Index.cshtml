@model List<ECommerce.AdminPanel.Models.CommentListViewModel>
@{
    ViewData["Title"] = "مدیریت نظرات";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">مدیریت نظرات</h4>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th class="border-top-0">نویسنده</th>
                            <th class="border-top-0">موضوع</th>
                            <th class="border-top-0">محتوا</th>
                            <th class="border-top-0">محصول/مقاله</th>
                            <th class="border-top-0">وضعیت</th>
                            <th class="border-top-0">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var comment in Model)
                            {
                                <tr>
                                    <td>@comment.AuthorName</td>
                                    <td>@comment.Title</td>
                                    <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@comment.Content</td>
                                    <td>@comment.TargetName</td>
                                    <td>
                                        <span class="badge @(comment.IsApproved ? "badge-success" : "badge-warning") font-weight-100">
                                            @(comment.IsApproved ? "تایید شده" : "در انتظار")
                                        </span>
                                    </td>
                                    <td>
                                        @if (!comment.IsApproved)
                                        {
                                            <form asp-action="Approve" asp-route-id="@comment.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-inverse btn-link p-0 p-r-10" title="تایید">
                                                    <i class="mdi mdi-check-circle"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Reject" asp-route-id="@comment.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-inverse btn-link p-0 p-r-10" title="رد">
                                                    <i class="mdi mdi-close-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@comment.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-inverse btn-link p-0" title="حذف" onclick="return confirm('آیا مطمئن هستید؟')">
                                                <i class="mdi mdi-delete"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    <i class="mdi mdi-information-outline font-24"></i>
                                    <p class="m-t-10">داده‌ای یافت نشد</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
