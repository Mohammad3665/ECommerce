@model List<ECommerce.AdminPanel.Models.BrandListViewModel>
@{
    ViewData["Title"] = "مدیریت برندها";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">مدیریت برندها</h4>
                    </div>
                    <div class="ml-auto">
                        <a asp-action="Create" class="btn btn-warning">
                            <i class="mdi mdi-tag-plus"></i> افزودن برند جدید
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    @if (Model.Any())
    {
        @foreach (var brand in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card" style="overflow: hidden;">
                    <div style="height: 160px; overflow: hidden; background: #f1f2f3; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(brand.LogoImageUrl))
                        {
                            <img src="~/@brand.LogoImageUrl" alt="@brand.Name" style="width: 100%; height: 160px; object-fit: cover;">
                        }
                        else
                        {
                            <i class="mdi mdi-tag text-muted" style="font-size: 48px;"></i>
                        }
                    </div>
                    <div class="card-body">
                        <h5 class="card-title m-b-0">@brand.Name</h5>
                        <p class="text-muted m-t-10 m-b-0" style="font-size: 13px;">@brand.Description</p>
                        <div class="d-flex justify-content-between align-items-center m-t-15">
                            <div>
                                <span class="badge @(brand.IsActive ? "badge-success" : "badge-danger") badge-pill">@(brand.IsActive ? "فعال" : "غیرفعال")</span>
                            </div>
                            <div>
                                <a asp-action="Edit" asp-route-slug="@brand.Slug" class="btn btn-sm btn-outline-warning" title="ویرایش">
                                    <i class="mdi mdi-lead-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-slug="@brand.Slug" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف" onclick="return confirm('آیا مطمئن هستید؟')">
                                        <i class="mdi mdi-delete"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body text-center text-muted">
                    <i class="mdi mdi-information-outline font-24"></i>
                    <p class="m-t-10">داده‌ای یافت نشد</p>
                </div>
            </div>
        </div>
    }
</div>
