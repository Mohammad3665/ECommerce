@model ECommerce.AdminPanel.Models.BrandFormViewModel
@{
    ViewData["Title"] = "ویرایش برند";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">ویرایش برند</h4>
                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Slug" />
                    <input type="hidden" asp-for="ExistingLogoUrl" />
                    <div class="form-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">نام برند</label>
                                    <input asp-for="Name" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">نام انگلیسی</label>
                                    <input asp-for="EnglishName" class="form-control" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">توضیحات</label>
                                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">وضعیت</label>
                                    <select asp-for="IsActive" class="form-control">
                                        <option value="true">فعال</option>
                                        <option value="false">غیرفعال</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ExistingLogoUrl))
                        {
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label class="control-label">لوگوی فعلی</label>
                                        <div>
                                            <img src="~/@Model.ExistingLogoUrl" style="width: 150px; height: 150px; object-fit: cover; border-radius: 5px;" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">لوگوی جدید</label>
                                    <div class="custom-file">
                                        <input type="file" name="LogoFile" class="custom-file-input" id="imageUpload" accept="image/*">
                                        <label class="custom-file-label" for="imageUpload">انتخاب لوگوی جدید</label>
                                    </div>
                                    <div class="mt-2">
                                        <img id="imagePreview" src="#" alt="پیش‌نمایش" style="max-width: 300px; max-height: 200px; display: none; border-radius: 5px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-success">
                            <i class="mdi mdi-content-save"></i> ذخیره تغییرات
                        </button>
                        <a asp-action="Index" class="btn btn-inverse">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('imageUpload').addEventListener('change', function (e) {
            var preview = document.getElementById('imagePreview');
            var file = e.target.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function (event) {
                    preview.src = event.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
