@{
    ViewData["Title"] = "لیست محصولات";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">لیست محصولات</h4>
                    </div>
                    <div class="ml-auto">
                        <a asp-action="Create" class="btn btn-danger">
                            <i class="mdi mdi-plus-circle-outline"></i> افزودن محصول جدید
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-4 col-md-6">
        <div class="card" style="overflow: hidden;">
            <div style="height: 200px; overflow: hidden; background: #f1f2f3; display: flex; align-items: center; justify-content: center;">
                <img src="~/assets/images/background/img5.png" alt="محصول" style="width: 100%; height: 200px; object-fit: cover;">
            </div>
            <div class="card-body">
                <h5 class="card-title m-b-0">نام محصول</h5>
                <div class="d-flex align-items-center m-t-10">
                    <span class="badge badge-info">دسته‌بندی</span>
                    <span class="badge badge-warning m-l-5">برند</span>
                </div>
                <div class="d-flex align-items-center m-t-15">
                    <h3 class="m-b-0 text-danger font-light" style="direction: rtl;">۱۲۵,۰۰۰ <small class="text-muted font-14">تومان</small></h3>
                    <div class="ml-auto">
                        <span class="badge badge-pill badge-success">موجود</span>
                    </div>
                </div>
            </div>
            <div class="card-body border-top" style="padding: 0.75rem 1.25rem;">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">موجودی: ۵۰ عدد</small>
                    <div>
                        <a asp-action="Edit" asp-route-id="1" class="btn btn-sm btn-outline-warning" title="ویرایش">
                            <i class="mdi mdi-lead-pencil"></i>
                        </a>
                        <a href="javascript:void(0)" class="btn btn-sm btn-outline-danger" title="حذف">
                            <i class="mdi mdi-delete"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
