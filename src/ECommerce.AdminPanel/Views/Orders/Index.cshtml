@model List<ECommerce.AdminPanel.Models.OrderListViewModel>
@{
    ViewData["Title"] = "لیست سفارشات";

    string GetStatusText(ECommerce.Domain.Enums.OrderStatus status) => status switch
    {
        ECommerce.Domain.Enums.OrderStatus.Pending => "در انتظار پرداخت",
        ECommerce.Domain.Enums.OrderStatus.Paid => "پرداخت شده",
        ECommerce.Domain.Enums.OrderStatus.Processing => "در حال پردازش",
        ECommerce.Domain.Enums.OrderStatus.Shipping => "در حال ارسال",
        ECommerce.Domain.Enums.OrderStatus.Delivered => "تحویل شده",
        ECommerce.Domain.Enums.OrderStatus.Cancelled => "لغو شده",
        _ => status.ToString()
    };

    string GetStatusBadgeClass(ECommerce.Domain.Enums.OrderStatus status) => status switch
    {
        ECommerce.Domain.Enums.OrderStatus.Pending => "label-warning",
        ECommerce.Domain.Enums.OrderStatus.Paid => "label-success",
        ECommerce.Domain.Enums.OrderStatus.Processing => "label-info",
        ECommerce.Domain.Enums.OrderStatus.Shipping => "label-primary",
        ECommerce.Domain.Enums.OrderStatus.Delivered => "label-success",
        ECommerce.Domain.Enums.OrderStatus.Cancelled => "label-danger",
        _ => "label-default"
    };
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">لیست سفارشات</h4>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover" id="zero_config">
                    <thead>
                        <tr>
                            <th class="border-top-0">شماره سفارش</th>
                            <th class="border-top-0">تعداد اقلام</th>
                            <th class="border-top-0">مجموع مبلغ</th>
                            <th class="border-top-0">تاریخ</th>
                            <th class="border-top-0">وضعیت</th>
                            <th class="border-top-0">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><a asp-action="Details" asp-route-id="@order.Id" class="font-medium">#@order.OrderNumber</a></td>
                                    <td>@order.ItemCount</td>
                                    <td>@order.TotalAmount.ToString("N0") تومان</td>
                                    <td>@order.OrderDate.ToString("yyyy/MM/dd")</td>
                                    <td>
                                        <span class="label @GetStatusBadgeClass(order.Status) font-weight-100">
                                            @GetStatusText(order.Status)
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@order.Id" class="text-inverse p-r-10" data-toggle="tooltip" title="جزئیات">
                                            <i class="ti-marker-alt"></i>
                                        </a>
                                        <a asp-action="ChangeStatus" asp-route-id="@order.Id" class="text-inverse p-r-10" data-toggle="tooltip" title="تغییر وضعیت">
                                            <i class="ti-reload"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    <i class="mdi mdi-information-outline font-24"></i>
                                    <p class="m-t-10">داده‌ای یافت نشد</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
