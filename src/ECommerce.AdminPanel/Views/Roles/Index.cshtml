@model List<ECommerce.AdminPanel.Models.RoleListViewModel>
@{
    ViewData["Title"] = "لیست نقش‌ها";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <h4 class="card-title">لیست نقش‌ها</h4>
                    </div>
                    <div class="ml-auto">
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="mdi mdi-shield-plus"></i> افزودن نقش جدید
                        </a>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th class="border-top-0">نام نقش</th>
                            <th class="border-top-0">نام نمایشی</th>
                            <th class="border-top-0">توضیحات</th>
                            <th class="border-top-0">سطح دسترسی</th>
                            <th class="border-top-0">پیش‌فرض</th>
                            <th class="border-top-0">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var role in Model)
                            {
                                <tr>
                                    <td><code>@role.Name</code></td>
                                    <td>@role.DisplayName</td>
                                    <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@role.Description</td>
                                    <td><span class="badge badge-info">@role.Level</span></td>
                                    <td>
                                        <span class="badge @(role.IsDefault ? "badge-success" : "badge-secondary") badge-pill">
                                            @(role.IsDefault ? "بله" : "خیر")
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-slug="@role.Name.ToLower().Replace(" ", "-")" class="text-inverse p-r-10" title="ویرایش">
                                            <i class="ti-marker-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    <i class="mdi mdi-information-outline font-24"></i>
                                    <p class="m-t-10">داده‌ای یافت نشد</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
