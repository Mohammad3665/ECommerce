@model ECommerce.AdminPanel.Models.ProductFormViewModel
@{
    ViewData["Title"] = "ویرایش محصول";
    var brands = ViewBag.Brands as dynamic ?? new List<dynamic>();
    var categories = ViewBag.Categories as dynamic ?? new List<dynamic>();
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">ویرایش محصول</h4>
                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Slug" />
                    <div class="form-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">نام محصول</label>
                                    <input asp-for="Name" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">نام انگلیسی</label>
                                    <input asp-for="EnglishName" class="form-control" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="control-label">قیمت</label>
                                    <input asp-for="Price" class="form-control" step="0.01" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="control-label">موجودی</label>
                                    <input asp-for="StockQuantity" class="form-control" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">دسته‌بندی فعلی: @Model.CategoryName</label>
                                    <select asp-for="CategoryId" class="form-control">
                                        <option value="">انتخاب دسته‌بندی</option>
                                        @foreach (dynamic cat in categories)
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">برند فعلی: @Model.BrandName</label>
                                    <select asp-for="BrandId" class="form-control">
                                        <option value="">انتخاب برند</option>
                                        @foreach (dynamic brand in brands)
                                        {
                                            <option value="@brand.Id">@brand.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">توضیحات کوتاه</label>
                                    <textarea asp-for="ShortDescription" class="form-control" rows="2"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">توضیحات کامل</label>
                                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                                </div>
                            </div>
                        </div>
                        @if (Model.Images?.Any() == true)
                        {
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label class="control-label">تصاویر فعلی</label>
                                        <div class="d-flex flex-wrap">
                                            @foreach (var img in Model.Images)
                                            {
                                                <div class="m-2" style="position: relative;">
                                                    <img src="~/@img.ImageUrl" style="width: 100px; height: 100px; object-fit: cover; border-radius: 5px;" />
                                                    @if (img.IsMain)
                                                    {
                                                        <span class="badge badge-success" style="position: absolute; top: 0; right: 0;">اصلی</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">تصاویر جدید</label>
                                    <div class="custom-file">
                                        <input type="file" name="ImageFiles" class="custom-file-input" id="imageUpload" accept="image/*" multiple>
                                        <label class="custom-file-label" for="imageUpload">انتخاب تصاویر جدید (امکان انتخاب چند تصویر)</label>
                                    </div>
                                    <div class="mt-2 d-flex flex-wrap" id="imagePreviewContainer">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="control-label">مشخصات فنی</label>
                                    <div id="specificationsContainer">
                                        @if (Model.Specifications?.Any() == true)
                                        {
                                            var idx = 0;
                                            @foreach (var spec in Model.Specifications)
                                            {
                                                <div class="row specification-row mb-2">
                                                    <div class="col-md-5">
                                                        <input type="text" name="Specifications[@idx].Key" class="form-control" value="@spec.Key" placeholder="نام مشخصه" />
                                                    </div>
                                                    <div class="col-md-5">
                                                        <input type="text" name="Specifications[@idx].Value" class="form-control" value="@spec.Value" placeholder="مقدار" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <button type="button" class="btn btn-danger btn-sm" onclick="removeSpec(this)">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                                idx++;
                                            }
                                        }
                                        else
                                        {
                                            <div class="row specification-row mb-2">
                                                <div class="col-md-5">
                                                    <input type="text" name="Specifications[0].Key" class="form-control" placeholder="نام مشخصه (مثلاً رنگ)" />
                                                </div>
                                                <div class="col-md-5">
                                                    <input type="text" name="Specifications[0].Value" class="form-control" placeholder="مقدار (مثلاً قرمز)" />
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeSpec(this)">
                                                        <i class="mdi mdi-delete"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-info mt-2" onclick="addSpec()">
                                        <i class="mdi mdi-plus"></i> افزودن مشخصه
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-success">
                            <i class="mdi mdi-content-save"></i> ذخیره تغییرات
                        </button>
                        <a asp-action="Index" class="btn btn-inverse">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var specIndex = @(Model.Specifications?.Any() == true ? Model.Specifications.Count : 1);
        function addSpec() {
            var container = document.getElementById('specificationsContainer');
            var row = document.createElement('div');
            row.className = 'row specification-row mb-2';
            row.innerHTML = '<div class="col-md-5"><input type="text" name="Specifications[' + specIndex + '].Key" class="form-control" placeholder="نام مشخصه" /></div>' +
                '<div class="col-md-5"><input type="text" name="Specifications[' + specIndex + '].Value" class="form-control" placeholder="مقدار" /></div>' +
                '<div class="col-md-2"><button type="button" class="btn btn-danger btn-sm" onclick="removeSpec(this)"><i class="mdi mdi-delete"></i></button></div>';
            container.appendChild(row);
            specIndex++;
        }
        function removeSpec(btn) {
            btn.closest('.specification-row').remove();
        }
        document.getElementById('imageUpload').addEventListener('change', function (e) {
            var container = document.getElementById('imagePreviewContainer');
            container.innerHTML = '';
            var files = e.target.files;
            for (var i = 0; i < files.length; i++) {
                var reader = new FileReader();
                reader.onload = function (event) {
                    var img = document.createElement('img');
                    img.src = event.target.result;
                    img.style.cssText = 'width: 150px; height: 150px; object-fit: cover; border-radius: 5px; margin: 5px;';
                    container.appendChild(img);
                };
                reader.readAsDataURL(files[i]);
            }
        });
    </script>
}
